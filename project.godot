; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="SM63 Redux"
config/version="0.2.0"
run/main_scene="uid://bkqukgs0ivej"
config/use_custom_user_dir=true
config/custom_user_dir_name="SM63Redux"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false
config/icon="uid://b7hhchui2qslg"
config/windows_native_icon="res://meta/icon.ico"

[autoload]

Singleton="*res://singleton/singleton.tscn"
DebugHandler="*uid://dyw3n7oxqk3vq"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
display_server/driver.linuxbsd="wayland"

[editor]

export/convert_text_resources_to_binary=false

[editor_plugins]

enabled=PackedStringArray("res://addons/redux_dev/plugin.cfg")

[file_customization]

folder_colors={
"res://assets/": "teal",
"res://core/": "red",
"res://game/": "blue",
"res://meta/": "yellow",
"res://proto/": "gray",
"res://singleton/": "orange",
"res://util/": "purple"
}

[global_group]

gui_touch=""

[gui]

theme/default_font_antialiasing=0
theme/custom="uid://jwr7shpg3llo"

