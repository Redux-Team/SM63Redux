[sub_resource type="GDScript" id="GDScript_ac0to"]
script/source = "extends RichTextLabel


func _ready() -> void:
	assign_text()
	Singleton.input_type_changed.connect(assign_text)


func assign_text() -> void:
	text = \"press %s to spin\" % ControlScheme.get_hint(\"spin\")
"

[sub_resource type="GDScript" id="GDScript_p32j3"]
script/source = "extends RichTextLabel


func _ready() -> void:
	assign_text()
	Singleton.input_type_changed.connect(assign_text)


func assign_text() -> void:
	text = \"press %s + %s to backflip\" % [ControlScheme.get_hint(\"crouch\"), ControlScheme.get_hint(\"jump\")]
"

[sub_resource type="GDScript" id="GDScript_o06jl"]
script/source = "extends RichTextLabel


func _ready() -> void:
	assign_text()
	Singleton.input_type_changed.connect(assign_text)


func assign_text() -> void:
	text = \"and press %s + %s + %s to do an angled backflip\" % [ControlScheme.get_hint(\"crouch\"), ControlScheme.get_hint(\"move_right\"), ControlScheme.get_hint(\"jump\")]
"

